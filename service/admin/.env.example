HOST=0.0.0.0
PORT=8010
LOG_LEVEL=INFO

DB_SERVICE_BASE_URL=http://127.0.0.1:8082
ADMIN_MANAGED_DOCS_PATH=./managed_docs
ADMIN_RUNTIME_CONFIG_PATH=./runtime/admin_config.json

ADMIN_AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_REFRESH_TOKEN_EXPIRE_DAYS=7

ADMIN_AUTO_REINDEX_ON_DOC_CHANGE=true
ADMIN_ALLOWED_DOC_EXTENSIONS=.md,.txt,.rst
ADMIN_MAX_UPLOAD_SIZE_KB=1024
ADMIN_DEFAULT_DOC_PROJECT=custom
